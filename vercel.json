{
  "version": 2,
  "git": {
    "deploymentEnabled": false
  },
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/proxy.js", "use": "@vercel/node" },
    { "src": "api/oliveyoung/search.js", "use": "@vercel/node" },
    { "src": "api/oliveyoung/inventory.js", "use": "@vercel/node" },
    { "src": "api/oliveyoung/options.js", "use": "@vercel/node" },
    { "src": "api/oliveyoung/stock.js", "use": "@vercel/node" },
    { "src": "api/oliveyoung/view-ranking.js", "use": "@vercel/node" },
    { "src": "api/oliveyoung/hot-ranking-history.js", "use": "@vercel/node" },
    {
      "src": "api/oliveyoung/hot-ranking-cron.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 800
      }
    },
    { "src": "api/oliveyoung/curator-redirect.js", "use": "@vercel/node" },
    { "src": "api/oliveyoung/curator-queue.js", "use": "@vercel/node" },
    { "src": "api/oliveyoung/shorten-proxy.js", "use": "@vercel/node" },
    { "src": "api/oliveyoung/landing-proxy.js", "use": "@vercel/node" },
    { "src": "api/favorites/sync.js", "use": "@vercel/node" },
    { "src": "api/kakao/geo.js", "use": "@vercel/node" }
  ],
  "crons": [
    {
      "path": "/api/oliveyoung/hot-ranking-cron",
      "schedule": "0 * * * *"
    }
  ],
  "routes": [
    { "src": "/guide/?", "dest": "/public/guide/index.html" },
    { "src": "/guide/([^/]+)/?", "dest": "/public/guide/$1/index.html" },
    { "src": "/blog/?", "dest": "/public/blog/index.html" },
    { "src": "/blog/([^/]+)/?", "dest": "/public/blog/$1/index.html" },
    { "src": "/site-map/?", "dest": "/public/site-map.html" },
    {
      "src": "/sw.js",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      },
      "dest": "/public/sw.js"
    },
    {
      "src": "/data/(.*)",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Cache-Control": "public, max-age=60, s-maxage=300"
      },
      "dest": "/public/data/$1"
    },
    { "src": "/api/favorites/sync", "dest": "/api/favorites/sync.js" },
    { "src": "/api/kakao/geo", "dest": "/api/kakao/geo.js" },
    { "src": "/api/oliveyoung/stock", "dest": "/api/oliveyoung/stock.js" },
    { "src": "/api/oliveyoung/view-ranking", "dest": "/api/oliveyoung/view-ranking.js" },
    {
      "src": "/api/oliveyoung/hot-ranking-history",
      "dest": "/api/oliveyoung/hot-ranking-history.js"
    },
    {
      "src": "/api/oliveyoung/hot-ranking-cron",
      "dest": "/api/oliveyoung/hot-ranking-cron.js"
    },
    { "src": "/api/oliveyoung/search", "dest": "/api/oliveyoung/search.js" },
    { "src": "/api/oliveyoung/inventory", "dest": "/api/oliveyoung/inventory.js" },
    { "src": "/api/oliveyoung/options", "dest": "/api/oliveyoung/options.js" },
    {
      "src": "/api/oliveyoung/curator-redirect",
      "dest": "/api/oliveyoung/curator-redirect.js"
    },
    {
      "src": "/api/oliveyoung/curator-queue",
      "dest": "/api/oliveyoung/curator-queue.js"
    },
    {
      "src": "/api/oliveyoung/shorten-proxy",
      "dest": "/api/oliveyoung/shorten-proxy.js"
    },
    {
      "src": "/api/oliveyoung/landing-proxy",
      "dest": "/api/oliveyoung/landing-proxy.js"
    },
    { "src": "/api/proxy(.*)", "dest": "/api/proxy.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
