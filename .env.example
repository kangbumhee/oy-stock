# OliveYoung Stock Checker environment template
# 실제 값은 GitHub Secrets 또는 Vercel Environment Variables에 저장한다.
# 이 파일에는 비밀값을 넣지 않는다.

# === OliveYoung curator auth ===
OY_REFRESH_COOKIE=
OY_CURATOR_COOKIE=
OY_SESSION_ID=
OY_LINKAGE_STRING=
OY_LINKAGE_JWT=
OLIVEYOUNG_LINKAGE_STRING=
OLIVEYOUNG_LINKAGE_JWT=
OLIVEYOUNG_AFFILIATE_REGISTER_ID=

# === Vercel automation ===
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_DEPLOY_HOOK=
VERCEL_ENV_TARGETS=production

# === Alert email ===
ALERT_EMAIL_FROM=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_TO=

# === GitHub / favorites sync ===
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main

# === Google Cloud Run deploy ===
GCP_PROJECT_ID=
GCP_SA_KEY=

# === Kakao ===
KAKAO_REST_KEY=

# === Local app ===
PUBLIC_APP_URL=http://localhost:3000

