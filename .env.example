# OliveYoung Stock Checker environment template
# 실제 값은 GitHub Secrets 또는 Vercel Environment Variables에 저장한다.
# 이 파일에는 비밀값을 넣지 않는다.

# === OliveYoung curator auth ===
# refresh-oy-cookie.mjs (로컬 HIL 로그인) — 저장소에 커밋하지 말 것
OY_USERNAME=
OY_PASSWORD=
OY_REFRESH_COOKIE=
OY_CURATOR_COOKIE=
OY_SESSION_ID=
OY_LINKAGE_STRING=
OY_LINKAGE_JWT=
OLIVEYOUNG_LINKAGE_STRING=
OLIVEYOUNG_LINKAGE_JWT=
OLIVEYOUNG_AFFILIATE_REGISTER_ID=

# === Vercel automation ===
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_DEPLOY_HOOK=
VERCEL_ENV_TARGETS=production

# === Alert email ===
ALERT_EMAIL_FROM=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_TO=

# === GitHub / favorites sync ===
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main

# === Google Cloud Run deploy ===
GCP_PROJECT_ID=
GCP_SA_KEY=

# === Kakao ===
KAKAO_REST_KEY=

# Vercel Cron/Blob for hot-item sales/revenue estimation
# Create a Vercel Blob store connected to the project so BLOB_READ_WRITE_TOKEN is injected.
BLOB_READ_WRITE_TOKEN=
# Optional but recommended: Vercel sends this as Authorization: Bearer <secret> for cron calls.
CRON_SECRET=
# KST busy windows use 30-minute collection by default; other hours collect hourly at minute 00.
HOT_RANK_BUSY_WINDOWS_KST=10-14,18-24
# Cost controls for adaptive collection.
HOT_RANK_BUSY_INTERVAL_MINUTES=30
HOT_RANK_QUIET_INTERVAL_MINUTES=60
HOT_RANK_PRIORITY_SALES_LIMIT=20
HOT_RANK_PRIORITY_REVENUE_LIMIT=20
HOT_RANK_RETRY_PER_RUN_LIMIT=12
HOT_RANK_OUT_OF_TOP_PER_RUN_LIMIT=10
# Legacy non-adaptive fallback limits. TOP100 ranking is fetched every run;
# stock is collected in rotating slices to avoid timeouts/rate blocks.
HOT_RANK_BUSY_STOCK_LIMIT=25
HOT_RANK_QUIET_STOCK_LIMIT=25
HOT_RANK_STOCK_TIMEOUT_MS=15000
# Keep enough observations for 1일/7일/30일 그래프.
HOT_RANK_HISTORY_DAYS=35
HOT_RANK_RUN_HISTORY_DAYS=30

# === Local app ===
PUBLIC_APP_URL=http://localhost:3000

# === Optional: cookie refresh script ===
# SLACK_WEBHOOK_URL=
# LANDING_PROXY_CHECK_URL=https://oy-stock.vercel.app/api/oliveyoung/landing-proxy?check=1

