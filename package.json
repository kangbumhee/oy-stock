{
  "name": "oliveyoung-stock-checker",
  "version": "8.0.0",
  "private": true,
  "scripts": {
    "start": "node server/server.mjs",
    "gcp-build": "PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install chromium",
    "setup:oy-cookie-profile": "node scripts/refresh-oy-cookie-from-profile.mjs --setup",
    "refresh:oy-cookie:chrome": "node scripts/refresh-oy-cookie-from-profile.mjs",
    "build:blog": "node scripts/build-blog-pages.js",
    "build:blog:daily": "node scripts/build-blog-pages.js --daily --limit 3 --scan-limit 80",
    "build:blog:assets": "node scripts/render-blog-product-assets.js",
    "submit:indexnow": "node scripts/submit-indexnow.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "nodemailer": "^6.9.16",
    "playwright": "^1.50.0"
  }
}
